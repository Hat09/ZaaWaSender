# ─── TELEGRAM BOT ─────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ─── AUTHORIZED USER ──────────────────────────────────────────────
# Telegram User ID yang boleh pakai bot (pisahkan koma jika > 1)
ALLOWED_USERS=123456789

# ─── ZAA SENDER BRANDING ──────────────────────────────────────────
# Nama profil yang akan di-set ke semua akun WA setelah connect
BOT_NAME=ZAA SENDER

# Footer teks yang tampil di bawah setiap pesan (italic kecil)
# Ini yang muncul seperti "100% PASTI WD" di screenshot referensi
MSG_FOOTER=ZAA SENDER

# Path ke file logo PNG/JPG untuk foto profil semua akun WA
# Jika tidak diset, bot mencari sessions/zaa-logo.png secara otomatis
# BOT_LOGO_PATH=/path/to/logo.png

# ─── DELAY ANTI-BANNED (millisecond) ─────────────────────────────
# Micro delay: jeda antar setiap pesan dalam satu shift
MICRO_DELAY_MIN=12000
MICRO_DELAY_MAX=35000

# Macro delay: istirahat antar setiap shift
MACRO_DELAY_MIN=60000
MACRO_DELAY_MAX=120000
